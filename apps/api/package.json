{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint ../../apps/api/src ../../apps/api/test --max-warnings=0",
    "lint:fix": "eslint ../../apps/api/src ../../apps/api/test --fix",
    "lint:ci": "npm run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --no-file-parallelism --pool=forks",
    "test:e2e": "vitest run -c vitest.config.e2e.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:run": "npm run typeorm -- migration:run -d src/database/typeorm-data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/database/typeorm-data-source.ts",
    "migration:show": "npm run typeorm -- migration:show -d src/database/typeorm-data-source.ts"
  },
  "dependencies": {
    "@blog/shared-contracts": "file:../../libs/shared-contracts",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@node-rs/argon2": "^2.0.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.0.0",
    "@opentelemetry/core": "^2.0.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.0.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.2",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
    "pg": "^8.16.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.24",
    "zod": "^3.25.76"
  },
  "nx": {
    "targets": {
      "build": {
        "dependsOn": [
          "shared-contracts:build"
        ]
      }
    }
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/passport": "^1.0.17",
    "@types/pg": "^8.15.4",
    "@types/supertest": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  }
}

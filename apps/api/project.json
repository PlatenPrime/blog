{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "dependsOn": ["shared-contracts:build"],
      "options": {
        "command": "eslint apps/api/src apps/api/test --max-warnings=0",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "dependsOn": ["shared-contracts:build"],
      "options": {
        "command": "eslint apps/api/src apps/api/test --fix",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint:ci": {
      "executor": "nx:run-commands",
      "dependsOn": ["shared-contracts:build"],
      "options": {
        "command": "eslint apps/api/src apps/api/test --max-warnings=0",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}

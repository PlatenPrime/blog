# ============================================================================
# Root .env.example
#
# Copy to `.env` (which is gitignored) and adjust values:
#     cp .env.example .env
#
# Loaders that pick up this file:
#   * NestJS API  -> @nestjs/config in apps/api (see apps/api/src/config/env-file-paths.ts)
#   * Docker Compose -> automatically reads .env from the directory where
#                       `docker compose ...` is invoked (repo root)
#
# Never commit real secrets. Values below are safe dev defaults.
# ============================================================================

# ---- API (apps/api) --------------------------------------------------------

# Initial port for the NestJS API. If busy, the bootstrap auto-increments
# up to 20 times before failing.
# Read by: apps/api/src/config/env.schema.ts -> rootEnvSchema; apps/api/src/main.ts -> listen port
PORT=4000

# Minimum log level for structured JSON logs (trace|debug|info|warn|error|fatal|silent).
# Read by: apps/api/src/config/env.schema.ts -> rootEnvSchema; apps/api/src/common/logging/
LOG_LEVEL=info

# Comma-separated whitelist of allowed CORS origins. Use "*" alone or mixed
# in to reflect any origin (dev only; will be banned together with
# credentials:true in Track 2).
# Read by: apps/api/src/config/env.schema.ts -> rootEnvSchema; apps/api/src/config/cors.config.ts -> buildCorsOptions()
CORS_ORIGINS=http://localhost:3000

# Per-request handler timeout (ms). Exceeded → HTTP 408 Request Timeout.
# Read by: apps/api/src/config/env.schema.ts -> rootEnvSchema; request-timeout interceptor
REQUEST_TIMEOUT_MS=30000

# Max wait for in-flight HTTP requests during SIGTERM/SIGINT before force exit.
# Read by: apps/api/src/config/env.schema.ts -> rootEnvSchema; ApiShutdownCoordinator
SHUTDOWN_GRACE_PERIOD_MS=10000

# OpenTelemetry (optional; default is in-process traces only — no collector)
# Read by: apps/api/src/config/otel-env.ts (pre-Nest bootstrap) + rootEnvSchema
OTEL_SERVICE_NAME=api
# none | otlp — use otlp only when a collector is running (see docs/LOCAL_SETUP.md)
OTEL_TRACES_EXPORTER=none
# Required when OTEL_TRACES_EXPORTER=otlp, e.g. http://127.0.0.1:4318/v1/traces
# OTEL_EXPORTER_OTLP_ENDPOINT=

# ---- PostgreSQL (docker-compose.yml :: service db) -------------------------

# Host for API readiness checks and future DB clients (loopback matches compose bind).
# Read by: apps/api/src/config/env.schema.ts -> rootEnvSchema; apps/api/src/health/health.module.ts
POSTGRES_HOST=127.0.0.1

# Superuser created by the postgres:16-alpine image on first boot.
POSTGRES_USER=blog

# Superuser password (dev-only; rotate for any non-local environment).
POSTGRES_PASSWORD=blog

# Database created on first boot.
POSTGRES_DB=blog_dev

# Host-side port mapping for `127.0.0.1:${POSTGRES_PORT}:5432`.
POSTGRES_PORT=5432

# Canonical Postgres URL for TypeORM (apps/api DatabaseModule).
# Read by: apps/api/src/config/env.schema.ts -> rootEnvSchema; apps/api/src/database/database.module.ts
# Default when unset: built from POSTGRES_* above.
DATABASE_URL=postgresql://blog:blog@127.0.0.1:5432/blog_dev

# ---- JWT (access tokens, apps/api AuthModule) ------------------------------

# HS256 signing secret (min 32 characters). Rotate for non-local deployments.
# Read by: apps/api/src/config/env.schema.ts -> rootEnvSchema; apps/api/src/auth/auth.module.ts
JWT_SECRET=dev-only-jwt-secret-change-before-production-32chars

# Access token lifetime (jsonwebtoken expiresIn, e.g. 15m, 1h, 900).
# Read by: apps/api/src/config/env.schema.ts -> rootEnvSchema; JwtModule signOptions
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token DB lifetime in milliseconds (default 30 days = 2592000000).
# Read by: apps/api/src/config/env.schema.ts; AuthService.refreshExpiresAt
JWT_REFRESH_EXPIRES_MS=2592000000

# ---- Service API key auth stub (machine-to-machine, optional) ---------------

# Optional shared secret for future service-to-service routes.
# Leave empty locally; set a real 32+ character secret only in private .env/secrets.
# Read by: apps/api/src/config/env.schema.ts; apps/api/src/auth/service-api-key.service.ts
SERVICE_API_KEY=

# ---- Login lockout (POST /auth/login, apps/api) ----------------------------

# Failed attempts per email within the window before temporary lockout.
# Read by: apps/api/src/config/env.schema.ts; LoginLockoutService
LOGIN_LOCKOUT_MAX_ATTEMPTS=5

# Streak window for counting failures (ms). Default 15 minutes.
LOGIN_LOCKOUT_WINDOW_MS=900000

# Lockout duration after threshold (ms). Default 15 minutes.
LOGIN_LOCKOUT_DURATION_MS=900000

# ---- Auth-sensitive rate limits (reset / resend verify, apps/api) -----------

# Requests per email and per IP within the window before temporary lockout.
# Read by: apps/api/src/config/env.schema.ts; AuthSensitiveRateLimitService
AUTH_SENSITIVE_RATE_MAX_ATTEMPTS=3

# Streak window for counting requests (ms). Default 1 hour.
AUTH_SENSITIVE_RATE_WINDOW_MS=3600000

# Lockout duration after threshold (ms). Default 1 hour.
AUTH_SENSITIVE_RATE_DURATION_MS=3600000

# ---- Global HTTP throttle (all routes except ops, apps/api) ----------------

# Max requests per client IP within the TTL window (in-memory; baseline for prod 292+).
# Read by: apps/api/src/config/env.schema.ts; ThrottlerModule in app.module.ts
GLOBAL_THROTTLE_LIMIT=100

# Throttle window length (ms). Default 1 minute.
GLOBAL_THROTTLE_TTL_MS=60000

# ---- SMTP (MailDev local capture, apps/api EmailService) -------------------

# Leave SMTP_HOST empty to disable outbound email (CI/e2e return tokens in JSON).
# Local dev with MailDev (docker compose service maildev):
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
SMTP_FROM=noreply@blog.local

# Base URL for verify/reset links in plain-text emails (empty = first CORS_ORIGINS).
APP_PUBLIC_BASE_URL=http://localhost:3000

# When true, register/reset still return tokens in JSON even if SMTP is enabled.
EMAIL_RETURN_TOKEN_IN_RESPONSE=false

# When true, login/refresh and JWT-protected routes require users.email_verified_at.
# Dev default false; set true in staging/production after verify-email is live.
REQUIRE_EMAIL_VERIFIED=false

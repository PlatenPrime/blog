{
  "name": "nestjs-st",
  "private": true,
  "description": "Monorepo: NestJS API + TanStack Start (Nx) — Blog/CMS learning track",
  "workspaces": [
    "app"
  ],
  "scripts": {
    "build": "npm run build -w app",
    "start": "npm run start -w app",
    "start:dev": "npm run start:dev -w app",
    "start:prod": "npm run start:prod -w app",
    "lint": "npm run lint -w app",
    "test": "npm run test -w app",
    "test:e2e": "npm run test:e2e -w app",
    "format": "npm run format -w app"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}

{
  "name": "nestjs-st",
  "private": true,
  "description": "Monorepo: NestJS API + TanStack Start (Nx) - Blog/CMS learning track",
  "workspaces": [
    "apps/api"
  ],
  "scripts": {
    "build": "nx run api:build",
    "start": "npm run start -w api",
    "start:dev": "npm run start:dev -w api",
    "start:prod": "npm run start:prod -w api",
    "lint": "nx run api:lint",
    "test": "nx run api:test",
    "test:e2e": "nx run api:test:e2e",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "nx": "nx",
    "nx:show": "nx show projects",
    "nx:graph": "nx graph"
  },
  "engines": {
    "node": ">=20.10.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.8.2",
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nx/eslint": "22.7.0",
    "@nx/jest": "22.7.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.2",
    "nx": "22.7.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.20.0"
  }
}
